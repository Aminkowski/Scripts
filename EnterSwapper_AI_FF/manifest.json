{
  "manifest_version": 3,
  "name": "Enter Swapper",
  "version": "1.0",
  "description": "Swaps Enter and Shift+Enter on specific sites.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "enter-swapper@novagate.local"
    }
  }
}
